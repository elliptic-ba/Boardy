{
  "name": "boardy",
  "version": "1.0.2",
  "description": "Local, encrypted block-based workspace",
  "main": "out/main/index.js",
  "desktopName": "boardy.desktop",
  "author": "Boardy",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --linux",
    "gen:icon": "electron scripts/gen-icon.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3-multiple-ciphers": "^12.10.0"
  },
  "devDependencies": {
    "@blocknote/core": "^0.51.4",
    "@blocknote/mantine": "^0.51.4",
    "@blocknote/react": "^0.51.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/core": "^9.3.1",
    "@mantine/hooks": "^9.3.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "~41.7.2",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "zustand": "^5.0.14"
  }
}
